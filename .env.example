# Supabase public client config. The anon key is safe to ship only with audited RLS.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_ISSUE_MEDIA_BUCKET=

# Public/accepted-client provider config. These are embedded in EAS builds and updates.
EXPO_PUBLIC_MAL_CLIENT_ID=
EXPO_PUBLIC_MAL_API_BASE_URL=https://api.myanimelist.net/v2
EXPO_PUBLIC_YOUTUBE_API_KEY=
EXPO_PUBLIC_YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_CLIENT_KEY=
EXPO_PUBLIC_SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
EXPO_PUBLIC_SPOTIFY_ACCOUNTS_URL=https://accounts.spotify.com/api/token
EXPO_PUBLIC_AZURE_TRANSLATOR_SUBSCRIPTION_KEY=
EXPO_PUBLIC_AZURE_TRANSLATOR_REGION=
EXPO_PUBLIC_AZURE_TRANSLATOR_API_BASE_URL=https://api.cognitive.microsofttranslator.com

# Optional user/provider integrations. Runtime UI usually stores these per-device.
EXPO_PUBLIC_JPDB_API_KEY=

# Debug flags
EXPO_PUBLIC_LOG_URL_READER=
